APP_NAME="Fundraising Dinner API"
ENVIRONMENT="development"
DEBUG="true"
 
# CORS
ALLOWED_ORIGINS="http://localhost:3000"
PUBLIC_WEB_URL="http://localhost:3000"

# Database
# Supabase (Postgres) connection string.
# Use ONE of these patterns:
#
# 1) Direct Postgres (recommended if you allow your IP in Supabase DB settings):
#    postgresql+psycopg://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
#
# 2) Supabase Pooler (recommended for serverless; uses port 6543):
#    postgresql+psycopg://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require
#
# Replace placeholders with values from Supabase → Project Settings → Database.
DATABASE_URL="postgresql+psycopg://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"

# Auth (MVP admin)
ADMIN_USERNAME="admin"
# Generate with: python -m app.core.security hash-password "your-password"
ADMIN_PASSWORD_HASH=""
JWT_SECRET_KEY="change-me"
JWT_ACCESS_TOKEN_EXPIRES_MINUTES="60"

# Uploads (local dev storage)
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB="10"

# Notifications
NOTIFICATIONS_ENABLED="true"
EMAIL_ENABLED="true"
SMS_ENABLED="false"
WHATSAPP_ENABLED="false"

# Email (Google SMTP with App Password)
EMAIL_FROM_ADDRESS="your-gmail@gmail.com"
EMAIL_FROM_NAME="MOSH Fundraising Dinner"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USERNAME="your-gmail@gmail.com"
SMTP_PASSWORD=""
SMTP_USE_TLS="true"
SMTP_USE_SSL="false"

# Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
# Example: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=""

# Admin recipients (comma-separated)
ADMIN_NOTIFICATION_EMAILS="admin@example.com"
ADMIN_NOTIFICATION_PHONES=""
ADMIN_NOTIFICATION_WHATSAPP_NUMBERS=""

